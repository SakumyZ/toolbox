<ContentDialog
    x:Class="ToolBox.Views.SshConfigPresetEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonText="保存"
    CloseButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <StackPanel Spacing="12" MinWidth="700">
        <TextBox x:Name="NameBox"
                 Header="预设名称"
                 PlaceholderText="例如：公司 GitHub / 个人 GitHub" />

        <TextBox x:Name="DescriptionBox"
                 Header="说明"
                 PlaceholderText="可选，描述这个预设的用途" />

        <TextBox x:Name="ContentBox"
                 Header="SSH Config 内容"
                 PlaceholderText="在这里粘贴整份 SSH config"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 Height="360"
                 IsSpellCheckEnabled="False"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />

        <TextBlock x:Name="ErrorText"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>