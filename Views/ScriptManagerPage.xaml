<Page
    x:Class="ToolBox.Views.ScriptManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

        <Grid Padding="24,20,24,16" RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="脚本管理器" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="CountText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="StatusMessage" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="TopSaveButton" Click="SaveScript_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE74E;" FontSize="12" />
                        <TextBlock Text="保存脚本" />
                    </StackPanel>
                </Button>
                <Button x:Name="TopRunButton" Click="RunScript_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE768;" FontSize="12" />
                        <TextBlock Text="运行脚本" />
                    </StackPanel>
                </Button>
                <Button x:Name="TopDuplicateButton" Click="DuplicateScript_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                        <TextBlock Text="复制脚本" />
                    </StackPanel>
                </Button>
                <Button x:Name="TopDeleteButton" Click="DeleteScript_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                        <TextBlock Text="删除脚本" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AccentButtonStyle}" Click="AddScript_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="新增脚本" />
                    </StackPanel>
                </Button>
                <Button Click="Refresh_Click" ToolTipService.ToolTip="刷新" Padding="8,6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="360,12,*">
            <Grid Grid.Column="0" RowDefinitions="Auto,*"
                  Padding="12" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <AutoSuggestBox x:Name="SearchBox" PlaceholderText="搜索脚本名称或说明"
                                QueryIcon="Find"
                                TextChanged="SearchBox_TextChanged" />

                <ListView x:Name="ScriptList" Grid.Row="1" Margin="0,12,0,0"
                          SelectionChanged="ScriptList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="Margin" Value="0,0,0,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="3" Padding="6,1">
                                        <TextBlock Text="{Binding ScriptType}" FontSize="10" Foreground="White" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="11" MaxLines="2"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding FileName}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{Binding ParameterSummary}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailPanel" Spacing="12">
                    <Border Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock Text="基础信息" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="脚本文件、说明和工作目录配置"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,8,160">
                                <TextBox x:Name="NameBox" Header="脚本名称" PlaceholderText="例如：批量导出日志" />
                                <ComboBox x:Name="ScriptTypeBox" Grid.Column="2" Header="脚本类型" IsEnabled="False" />
                            </Grid>

                            <TextBox x:Name="DescriptionBox" Header="脚本说明"
                                     PlaceholderText="可选，描述脚本的用途"
                                     AcceptsReturn="True" Height="72" TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="*,8,Auto,8,Auto">
                                <TextBox x:Name="ScriptPathBox" Header="脚本文件"
                                         PlaceholderText="导入后的脚本文件路径" IsReadOnly="True" />
                                <Button Grid.Column="2" Click="BrowseScript_Click" VerticalAlignment="Bottom">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE838;" FontSize="12" />
                                        <TextBlock Text="导入脚本" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="OpenScriptFolderButton" Grid.Column="4"
                                        Click="OpenScriptFolder_Click" VerticalAlignment="Bottom">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="12" />
                                        <TextBlock Text="打开目录" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBox x:Name="WorkingDirectoryBox"
                                     Header="工作目录"
                                     PlaceholderText="留空则使用脚本所在目录" />
                        </StackPanel>
                    </Border>

                    <Border Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid RowDefinitions="Auto,Auto">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,8">
                                <TextBlock Text="参数定义" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Grid.Column="1" x:Name="ParameterHintText"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <Button Grid.Column="2" Click="AddParameter_Click" Padding="8,6">
                                    <FontIcon Glyph="&#xE710;" FontSize="12" />
                                </Button>
                                <Button Grid.Column="3" Click="EditParameter_Click" Padding="8,6" Margin="6,0,0,0">
                                    <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                </Button>
                                <Button Grid.Column="4" Click="DeleteParameter_Click" Padding="8,6" Margin="6,0,0,0">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                </Button>
                            </Grid>

                            <ListView x:Name="ParameterList" Grid.Row="1" SelectionMode="Single"
                                      DoubleTapped="ParameterList_DoubleTapped"
                                      MinHeight="120" MaxHeight="240">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="10,8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,120,110">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SecondaryText}" FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding ControlType}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="2" Text="{Binding RequirementText}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel>
                                    <TextBlock Text="运行参数" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="根据参数定义自动生成表单。交互脚本可切换为新终端运行。"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="OpenInTerminalCheckBox"
                                          Grid.Column="1"
                                          Content="在新终端中运行"
                                          VerticalAlignment="Top"
                                          Margin="12,0,0,0" />
                            </Grid>
                            <StackPanel x:Name="RunParameterHost" Spacing="10" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel>
                                    <TextBlock Text="命令预览" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="复制的是脚本调用命令本身，便于直接粘贴到外部终端执行。"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <Button x:Name="CopyCommandButton" Grid.Column="1"
                                        Click="CopyCommandPreview_Click" Padding="10,6"
                                        VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                        <TextBlock Text="复制命令" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBox x:Name="CommandPreviewBox"
                                     Margin="0,10,0,0"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     TextWrapping="Wrap"
                                     MinHeight="96"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>

                    <Border Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="执行输出" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBox x:Name="OutputBox"
                                     Margin="0,8,0,0"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     IsReadOnly="True"
                                     MinHeight="320"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
