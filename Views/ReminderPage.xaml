<Page
    x:Class="ToolBox.Views.ReminderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24,20,24,16" RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="定时器管理" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="CountText" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="StatusMessage" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource AccentButtonStyle}" Click="AddReminder_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="新增提醒" />
                    </StackPanel>
                </Button>
                <Button Click="Refresh_Click" ToolTipService.ToolTip="刷新" Padding="8,6"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Grid Padding="16,8" Margin="0,0,0,2"
                  ColumnDefinitions="120,*,90,150,150,80,120"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  CornerRadius="6,6,0,0"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
                <TextBlock Text="类型" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="提醒内容" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="2" Text="频率" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="3" Text="下一次触发" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="4" Text="最近触发" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="5" Text="状态" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Grid.Column="6" Text="操作" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
            </Grid>

            <ListView x:Name="ReminderList" Grid.Row="1" SelectionMode="None" Padding="0"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,1,1"
                      CornerRadius="0,0,6,6">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="16,8" />
                        <Setter Property="MinHeight" Value="48" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="120,*,90,150,150,80,120">
                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left"
                                    Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                <TextBlock Text="{Binding Category}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Message}" FontSize="11" MaxLines="1"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding FrequencyText}" FontSize="12"
                                       FontFamily="Consolas" VerticalAlignment="Center" />

                            <TextBlock Grid.Column="3" Text="{Binding NextTriggerText}" FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <TextBlock Grid.Column="4" Text="{Binding LastTriggeredText}" FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <Border Grid.Column="5" CornerRadius="3" Padding="8,3"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{Binding StatusBrush}">
                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                           Foreground="White" FontWeight="SemiBold" />
                            </Border>

                            <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="2"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Click="ToggleReminder_Click" Tag="{Binding Id}"
                                        ToolTipService.ToolTip="启用/停用" Padding="6" Background="Transparent">
                                    <FontIcon Glyph="{Binding ToggleGlyph}" FontSize="13" />
                                </Button>
                                <Button Click="EditReminder_Click" Tag="{Binding Id}"
                                        ToolTipService.ToolTip="编辑" Padding="6" Background="Transparent">
                                    <FontIcon Glyph="&#xE70F;" FontSize="13" />
                                </Button>
                                <Button Click="DeleteReminder_Click" Tag="{Binding Id}"
                                        ToolTipService.ToolTip="删除" Padding="6" Background="Transparent">
                                    <FontIcon Glyph="&#xE74D;" FontSize="13"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>