<Page
    x:Class="ToolBox.Views.PortViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24,20,24,16" RowDefinitions="Auto,Auto,*">

        <!-- Row 0: 标题栏 -->
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="端口查看器" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="CountText" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <AutoSuggestBox x:Name="SearchBox" PlaceholderText="搜索端口、进程名..."
                                QueryIcon="Find" Width="220"
                                TextChanged="SearchBox_TextChanged"
                                VerticalAlignment="Center" />
                <ComboBox x:Name="ProtocolFilter" Width="100"
                          SelectionChanged="Filter_Changed" VerticalAlignment="Center">
                    <ComboBoxItem Content="全部" IsSelected="True" />
                    <ComboBoxItem Content="TCP" />
                    <ComboBoxItem Content="UDP" />
                </ComboBox>
                <ComboBox x:Name="StateFilter" Width="130"
                          SelectionChanged="Filter_Changed" VerticalAlignment="Center">
                    <ComboBoxItem Content="全部状态" IsSelected="True" />
                    <ComboBoxItem Content="LISTEN" />
                    <ComboBoxItem Content="ESTABLISHED" />
                    <ComboBoxItem Content="TIME_WAIT" />
                    <ComboBoxItem Content="CLOSE_WAIT" />
                </ComboBox>
                <ToggleButton x:Name="ListenOnlyToggle" Click="Filter_Click"
                              ToolTipService.ToolTip="仅显示监听端口" Padding="8,6"
                              VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE71B;" FontSize="14" />
                </ToggleButton>
                <Button Click="Refresh_Click" ToolTipService.ToolTip="刷新" Padding="8,6"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: 表头 -->
        <Grid Grid.Row="1" Padding="16,8" Margin="0,0,0,2"
              ColumnDefinitions="70,100,80,150,80,100,*,40"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              CornerRadius="6,6,0,0"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
            <TextBlock Text="协议" FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="1" Text="本地地址" FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="2" Text="端口" FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="3" Text="远程地址" FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="4" Text="状态" FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="5" Text="PID" FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="6" Text="进程" FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="7" Text="" FontSize="12" />
        </Grid>

        <!-- Row 2: 列表 -->
        <ListView x:Name="PortList" Grid.Row="2" SelectionMode="None" Padding="0"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,1,1"
                  CornerRadius="0,0,6,6">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="16,6" />
                    <Setter Property="MinHeight" Value="36" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="70,100,80,150,80,100,*,40">
                        <!-- 协议 -->
                        <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left"
                                Background="{Binding ProtocolBrush}">
                            <TextBlock Text="{Binding Protocol}" FontSize="11"
                                       Foreground="White" FontWeight="SemiBold" />
                        </Border>

                        <!-- 本地地址 -->
                        <TextBlock Grid.Column="1" Text="{Binding LocalAddress}"
                                   FontSize="12" FontFamily="Consolas"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                        <!-- 端口 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding LocalPortText}" FontSize="13"
                                       FontWeight="SemiBold" FontFamily="Consolas"
                                       Foreground="{Binding PortBrush}" />
                            <FontIcon Glyph="&#xE735;" FontSize="9"
                                      Foreground="Gold" Visibility="{Binding IsCommonPortVis}" />
                        </StackPanel>

                        <!-- 远程地址 -->
                        <TextBlock Grid.Column="3" FontSize="12" FontFamily="Consolas"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{Binding RemoteAddress}" /><Run Text=":" /><Run Text="{Binding RemotePortText}" />
                        </TextBlock>

                        <!-- 状态 -->
                        <Border Grid.Column="4" CornerRadius="3" Padding="6,2"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Background="{Binding StateBrush}">
                            <TextBlock Text="{Binding State}" FontSize="10" Foreground="White" />
                        </Border>

                        <!-- PID -->
                        <TextBlock Grid.Column="5" Text="{Binding PidText}" FontSize="12"
                                   FontFamily="Consolas" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- 进程名 -->
                        <TextBlock Grid.Column="6" Text="{Binding ProcessName}" FontSize="12"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   ToolTipService.ToolTip="{Binding ProcessPath}" />

                        <!-- 操作 -->
                        <Button Grid.Column="7" Click="KillProcess_Click" Tag="{Binding Pid}"
                                ToolTipService.ToolTip="结束进程" Padding="4" Background="Transparent"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE711;" FontSize="12"
                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 加载中 -->
        <ProgressRing x:Name="LoadingRing" Grid.Row="2" IsActive="False"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Width="40" Height="40" />
    </Grid>
</Page>
