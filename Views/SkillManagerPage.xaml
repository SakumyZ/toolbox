<Page
    x:Class="ToolBox.Views.SkillManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24,20,24,16" RowDefinitions="Auto,Auto,*">
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="Skill 切换管理" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="CountText" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="StatusMessage" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Click="SaveSettings_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="12" />
                        <TextBlock Text="保存目录配置" />
                    </StackPanel>
                </Button>
                <Button Click="Refresh_Click" ToolTipService.ToolTip="刷新" Padding="8,6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" Margin="0,0,0,12">
            <Grid Padding="16,14" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                  RowDefinitions="Auto,Auto" ColumnDefinitions="*,16,*">
                <TextBox x:Name="ActivePathBox"
                         Header="启用目录"
                         PlaceholderText="例如：%USERPROFILE%\.agents\skills" />
                <TextBox x:Name="InactivePathBox" Grid.Column="2"
                         Header="停用目录"
                         PlaceholderText="例如：D:\Backup\AI\skills" />

                <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0"
                           Text="关闭 skill 时会把整个 skill 文件夹移动到停用目录；重新开启时再移动回启用目录。"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,12,0,0" ColumnDefinitions="280,140,140,*">
                <AutoSuggestBox x:Name="SearchBox" PlaceholderText="搜索 skill 名称、别名或描述..."
                                QueryIcon="Find" TextChanged="SearchBox_TextChanged" />
                <ComboBox x:Name="CategoryFilter" Grid.Column="1" Margin="12,0,0,0"
                          SelectionChanged="Filter_Changed" />
                <ComboBox x:Name="StateFilter" Grid.Column="2" Margin="12,0,0,0"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="全部状态" IsSelected="True" />
                    <ComboBoxItem Content="已启用" Tag="Active" />
                    <ComboBoxItem Content="已停用" Tag="Inactive" />
                </ComboBox>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <ListView x:Name="SkillList" SelectionMode="None" Padding="0"
                      Background="Transparent" BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0,0,0,8" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="14,8"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              CornerRadius="8"
                              ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Border Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="6,1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category}" FontSize="11" VerticalAlignment="Center" />
                                    </Border>
                                    <Button Click="EditSkill_Click" Tag="{Binding SkillId}" Padding="8,2" MinHeight="28" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                            <TextBlock Text="编辑别名/分类" FontSize="12" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <ToggleSwitch OnContent="开启"
                                              OffContent="关闭"
                                              IsOn="{Binding IsActive}"
                                              Tag="{Binding SkillId}"
                                              Toggled="SkillToggle_Toggled" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ProgressRing x:Name="LoadingRing" IsActive="False"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Width="40" Height="40" />
        </Grid>
    </Grid>
</Page>