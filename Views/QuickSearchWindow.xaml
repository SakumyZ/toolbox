<Window
    x:Class="ToolBox.Views.QuickSearchWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="快速搜索">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="16" RowDefinitions="Auto,*,Auto">
        <!-- 搜索框 -->
        <AutoSuggestBox x:Name="SearchInput" PlaceholderText="搜索代码片段... (Esc 关闭)"
                        QueryIcon="Find" FontSize="16" Padding="8"
                        QuerySubmitted="SearchInput_QuerySubmitted"
                        TextChanged="SearchInput_TextChanged"
                        KeyDown="SearchInput_KeyDown" />

        <!-- 搜索结果 -->
        <ListView x:Name="ResultList" Grid.Row="1" Margin="0,8,0,0"
                  SelectionMode="Single"
                  DoubleTapped="ResultList_DoubleTapped"
                  KeyDown="ResultList_KeyDown">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,6" ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE735;" FontSize="11" Foreground="Gold"
                                          Visibility="{Binding IsFavoriteVisibility}" />
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="3" Padding="5,1"
                                        Visibility="{Binding LanguageVisibility}">
                                    <TextBlock Text="{Binding Language}" FontSize="10" Foreground="White" />
                                </Border>
                                <TextBlock Text="{Binding Tags}" FontSize="10"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding CodePreview}" FontSize="11" MaxLines="1"
                                       FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Enter 复制" FontSize="10"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 底部提示 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Spacing="16" Margin="0,8,0,0">
            <TextBlock Text="Enter 复制并关闭" FontSize="11"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="Esc 关闭" FontSize="11"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </Grid>
</Window>
