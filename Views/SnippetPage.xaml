<Page
    x:Class="ToolBox.Views.SnippetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24,20,24,16" RowDefinitions="Auto,*">
        <!-- 顶部工具栏 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="代码片段" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="CountText" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <AutoSuggestBox x:Name="SearchBox" PlaceholderText="搜索片段..." QueryIcon="Find"
                                Width="240" QuerySubmitted="SearchBox_QuerySubmitted"
                                TextChanged="SearchBox_TextChanged" VerticalAlignment="Center" />
                <ComboBox x:Name="LanguageFilter" PlaceholderText="语言" Width="120"
                          SelectionChanged="LanguageFilter_SelectionChanged" VerticalAlignment="Center" />
                <ToggleButton x:Name="FavoriteFilter" Click="FavoriteFilter_Click"
                              ToolTipService.ToolTip="只看收藏" Padding="8,6" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE735;" FontSize="14" />
                </ToggleButton>
                <Button Style="{StaticResource AccentButtonStyle}" Click="AddSnippet_Click"
                        ToolTipService.ToolTip="新增片段 (Ctrl+Alt+N)" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="新增" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 内容区：左侧文件夹 | 中间列表 | 右侧预览 -->
        <Grid Grid.Row="1" ColumnDefinitions="200,12,*,12,*">

            <!-- ===== 左侧：文件夹面板 ===== -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*"
                  Padding="12" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBlock Text="文件夹" Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Click="AddFolder_Click" ToolTipService.ToolTip="新建文件夹"
                            Padding="4" Background="Transparent">
                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                    </Button>
                </Grid>

                <ListView x:Name="FolderList" Grid.Row="1" SelectionMode="Single"
                          SelectionChanged="FolderList_SelectionChanged"
                          Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="MinHeight" Value="32" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*" Height="24">
                                <FontIcon Glyph="&#xE8B7;" FontSize="13" Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- ===== 中间：片段列表 ===== -->
            <Grid Grid.Column="2" RowDefinitions="*"
                  Padding="0" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">

                <ListView x:Name="SnippetList" Grid.Row="0" SelectionMode="Single" Padding="4"
                          SelectionChanged="SnippetList_SelectionChanged"
                          DoubleTapped="SnippetList_DoubleTapped">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="0,1" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE735;" FontSize="11"
                                                  Foreground="Gold" Visibility="{Binding IsFavorite}" />
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="3" Padding="6,1" Visibility="{Binding LanguageVisibility}">
                                            <TextBlock Text="{Binding Language}" FontSize="10"
                                                       Foreground="White" />
                                        </Border>
                                        <TextBlock Text="{Binding Tags}" FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding CodePreview}" FontSize="11" MaxLines="1"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2"
                                            VerticalAlignment="Center">
                                    <Button Click="CopySnippet_Click" Tag="{Binding Id}"
                                            ToolTipService.ToolTip="复制" Padding="6" Background="Transparent">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                                    </Button>
                                    <Button Click="DeleteSnippet_Click" Tag="{Binding Id}"
                                            ToolTipService.ToolTip="删除" Padding="6" Background="Transparent">
                                        <FontIcon Glyph="&#xE74D;" FontSize="13" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 空状态 -->
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Spacing="12" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE943;" FontSize="42"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="还没有代码片段" HorizontalAlignment="Center" FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button Content="添加第一个片段" Style="{StaticResource AccentButtonStyle}"
                            Click="AddSnippet_Click" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- ===== 右侧：详情/编辑面板 ===== -->
            <Grid x:Name="DetailPanel" Grid.Column="4" Visibility="Collapsed"
                  RowDefinitions="Auto,Auto,Auto,*,Auto"
                  Padding="16,12" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">

                <!-- Row 0: 标题 -->
                <TextBox x:Name="DetailTitle" PlaceholderText="片段标题"
                         FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />

                <!-- Row 1: 语言 + 文件夹 -->
                <Grid Grid.Row="1" ColumnDefinitions="*,8,*" Margin="0,0,0,8">
                    <ComboBox x:Name="DetailLanguage" PlaceholderText="选择语言"
                              IsEditable="True" HorizontalAlignment="Stretch" />
                    <ComboBox x:Name="DetailFolder" Grid.Column="2"
                              PlaceholderText="所属文件夹" HorizontalAlignment="Stretch" />
                </Grid>

                <!-- Row 2: 描述 + 标签 -->
                <Grid Grid.Row="2" ColumnDefinitions="*,8,*" Margin="0,0,0,8">
                    <TextBox x:Name="DetailDesc" PlaceholderText="描述/备注 (可选)" />
                    <TextBox x:Name="DetailTags" Grid.Column="2" PlaceholderText="标签 (逗号分隔)" />
                </Grid>

                <!-- Row 3: 代码编辑器 -->
                <TextBox x:Name="DetailCode" Grid.Row="3" AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas" FontSize="13"
                         PlaceholderText="在此输入或粘贴代码..."
                         Margin="0,0,0,8" Padding="12,10"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />

                <!-- Row 4: 操作栏 -->
                <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Click="ToggleFavorite_Click" ToolTipService.ToolTip="收藏/取消收藏"
                                Padding="6" Background="Transparent">
                            <FontIcon x:Name="DetailFavIcon" Glyph="&#xE734;" FontSize="14" />
                        </Button>
                        <Button Click="DeleteCurrent_Click" ToolTipService.ToolTip="删除当前片段"
                                Padding="6" Background="Transparent">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Click="CopyPreview_Click" ToolTipService.ToolTip="复制代码" Padding="10,6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                <TextBlock Text="复制" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Click="SaveDetail_Click" Style="{StaticResource AccentButtonStyle}" Padding="10,6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE74E;" FontSize="12" />
                                <TextBlock Text="保存" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- 右侧空状态提示（无选中时） -->
            <Grid x:Name="DetailEmpty" Grid.Column="4"
                  Padding="16" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE8A1;" FontSize="36"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="选择一个片段查看或编辑" FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
